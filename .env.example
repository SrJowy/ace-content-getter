# Configuración de M3U Content Getter
# Copia este archivo a .env y edita los valores según tus necesidades

# URL del archivo m3u a descargar
# Ejemplo: http://192.168.1.100:8888/playlist.m3u
M3U_URL=http://ejemplo.com/playlist.m3u

# Puerto en el que correrá el servidor HTTP
# El servidor será accesible en http://localhost:{SERVER_PORT}
SERVER_PORT=8080

# IP original a reemplazar en el contenido del m3u
# Por defecto busca 127.0.0.1 (localhost)
OLD_IP=127.0.0.1

# IP nueva a usar en lugar de la antigua
# Reemplazará todas las instancias de OLD_IP por NEW_IP
NEW_IP=192.168.1.151

# Intervalo de actualización automática en horas
# La aplicación descargará el archivo m3u cada X horas
# Por defecto: 12 horas
UPDATE_INTERVAL=12

# Ejemplos adicionales:
# Reemplazar cualquier IP:
# OLD_IP=192.168.1.100
# NEW_IP=192.168.1.200
#
# Actualizar cada 6 horas:
# UPDATE_INTERVAL=6
#
# Actualizar cada 24 horas:
# UPDATE_INTERVAL=24
